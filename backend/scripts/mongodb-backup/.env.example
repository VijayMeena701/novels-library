# Shared/common settings for the MongoDB backup scripts.
# Copy this file to .env in this directory.

# Active backup environment profile. Loads .env.<BACKUP_ENV> after this file.
# BACKUP_ENV=local

# Optional: Directory containing mongodump.exe and mongorestore.exe on Windows
# MONGODB_TOOLS_DIR=C:\Program Files\MongoDB\Tools\100\bin

# Optional: Include Atlas App Services export (triggers/functions)
# INCLUDE_ATLAS=false
# ATLAS_PUBLIC_KEY=abcd
# ATLAS_PRIVATE_KEY=...
# ATLAS_GROUP_ID=...
# ATLAS_APP_ID=...
