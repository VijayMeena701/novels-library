#######################################
# Base Seed Variables (Modify these for your deployment)
#######################################
export PRIMARY_DOMAIN="your-domain.com"
export DB_NAME="your database name"
# Production Authentication (Leave empty or default for local development)
export DB_USER="your_database_user"
export DB_PASSWORD="your_database_password"
# Protocol: Use "mongodb" for local, "mongodb+srv" for Atlas clusters
export MONGO_PROTOCOL="mongodb+srv" 
export MONGO_HOST="your-atlas-cluster.xxxx.mongodb.net" # or "127.0.0.1:27017" for local

export FRONTEND_SUBDOMAIN="novels-library"

#######################################
# Core Server Settings
#######################################
export NODE_ENV="development"
export HOST="0.0.0.0"
export PORT="5050"
export LOG_LEVEL="info"
export SHUTDOWN_TIMEOUT_MS="8000"

#######################################
# Database Configuration
#######################################
# Check if credentials are provided
if [ -n "${DB_USER}" ] && [ -n "${DB_PASSWORD}" ] && [ "${DB_USER}" != "your_database_user" ]; then
    export MONGO_AUTH="${DB_USER}:${DB_PASSWORD}@"
else
    export MONGO_AUTH=""
fi

export MONGODB_URI="${MONGO_PROTOCOL}://${MONGO_AUTH}${MONGO_HOST}/${DB_NAME}"
export BACKUP_DATABASE="${DB_NAME}"

# Used only by backup/restore scripts
# export SOURCE_MONGODB_URI=""
# export TARGET_MONGODB_URI=""
export BACKUP_DIR="./backups"
export INCLUDE_ATLAS="false"
export DUMP_USERS="false"
export RESTORE_DROP="false"
export RESTORE_STOP_ON_ERROR="false"

#######################################
# Security
#######################################
# WARNING: Replace this with a secure 64-character random string in production!
export JWT_SECRET="development-secret-key-12345!@#"

#######################################
# CORS and Frontend Origins
#######################################
export FRONTEND_ORIGIN="https://${FRONTEND_SUBDOMAIN}.${PRIMARY_DOMAIN}"
export CORS_ORIGINS="https://${FRONTEND_SUBDOMAIN}.${PRIMARY_DOMAIN},http://localhost:3000,http://localhost:3001"

#######################################
# Admin Layout
#######################################
export ADMIN_EMAIL="admin@${PRIMARY_DOMAIN}"

#######################################
# Rate Limiting
#######################################
export RATE_LIMIT_MAX="1000"
export RATE_LIMIT_WINDOW_MS="60000"

#######################################
# Infrastructure Services (Redis)
#######################################
export REDIS_ENABLED="true"
export REDIS_URL="redis://127.0.0.1:6379"

#######################################
# Google OAuth Integration
#######################################
export GOOGLE_CLIENT_ID="<YOUR_GOOGLE_CLIENT_ID>"
export GOOGLE_CLIENT_SECRET="<YOUR_GOOGLE_CLIENT_SECRET>"
export GOOGLE_CALLBACK_URL="https://api.${PRIMARY_DOMAIN}/api/auth/google/callback"

#######################################
# SMTP Configuration (Cleanly Escaped)
#######################################
# export SMTP_HOST="smtp.mailtrap.io"
# export SMTP_PORT="2525"
# export SMTP_USER="your_user_id"
# export SMTP_PASS="your_password"
# export SMTP_FROM="Novel Library Scraper <noreply@${PRIMARY_DOMAIN}>"

#######################################
# AI Translation Modules
#######################################
export AI_TRANSLATION_PROVIDER="gemini"
export GEMINI_API_KEY="your_gemini_api_key"
export GEMINI_TRANSLATION_MODEL="gemini-2.5-flash"

export DEFAULT_TRANSLATION_TARGET_LANGUAGE="English"
export AI_TRANSLATION_MAX_INPUT_CHARS="60000"
export AI_TRANSLATION_TIMEOUT_MS="60000"

#######################################
# Scraper / Background Workers
#######################################
export SCRAPER_HEADLESS="true"
export SCRAPER_USER_DATA_DIR=".scraper-profile"
export SCRAPER_NAVIGATION_TIMEOUT_MS="30000"
export SCRAPER_RENDER_WAIT_MS="750"
export SCRAPER_CHALLENGE_WAIT_MS="15000"
export SCRAPER_CHAPTER_DELAY_MS="0"
export SCRAPER_CHAPTER_CONCURRENCY="8"
export SCRAPER_LIST_PAGE_CONCURRENCY="3"
export RECOVER_PROCESSING_JOBS_ON_START="true"

#######################################
# Storage Configurations
#######################################
export COVER_STORAGE_DIR="storage"
export COVER_DOWNLOAD_TIMEOUT_MS="20000"
export COVER_IMAGE_MAX_BYTES="10485760"

mongodb+srv://abc_user:password@novels-library.cluster.mongodb.net/novels-library