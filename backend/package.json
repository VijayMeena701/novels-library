{
  "name": "backend",
  "version": "1.0.0",
  "description": "Novel library tracker and archiver backend API",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('./dist',{recursive:true,force:true});\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test",
    "test:watch": "node --watch --import tsx --test",
    "test:coverage": "node --test --experimental-test-coverage --import tsx",
    "check": "npm run typecheck && npm run lint && npm run test && npm run format:check",
    "ci": "npm run check",
    "migrate": "tsx migrate.ts",
    "migrate:list": "tsx migrate.ts --list",
    "migrate:dry-run": "tsx migrate.ts --dry-run"
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/under-pressure": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.80.2",
    "casbin": "^5.35.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "mongoose": "^8.2.2",
    "nodemailer": "^9.0.3",
    "puppeteer": "^25.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.28",
    "@types/nodemailer": "^6.4.14",
    "eslint": "^9.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.64.0"
  }
}
