{
  "name": "backend",
  "version": "1.0.0",
  "description": "Novel library tracker and archiver backend API",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && tsc-alias",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit -p tsconfig.all.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "ci": "npm run check && npm run build",
    "migrate": "tsx migrate.ts",
    "migrate:list": "tsx migrate.ts --list",
    "migrate:dry-run": "tsx migrate.ts --dry-run",
    "backup": "tsx scripts/mongodb-backup/cli.ts",
    "backup:export": "tsx scripts/mongodb-backup/backup.ts",
    "backup:restore": "tsx scripts/mongodb-backup/restore.ts"
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/under-pressure": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.80.2",
    "casbin": "^5.35.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "mongoose": "^8.2.2",
    "nodemailer": "^9.0.3",
    "puppeteer": "^25.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.28",
    "@types/nodemailer": "^6.4.14",
    "eslint": "^9.18.0",
    "jiti": "^2.0.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^12.1.0",
    "prettier": "^3.5.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.7.1",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "mongodb-memory-server": "^10.0.0"
  }
}
